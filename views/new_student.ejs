<% layout('layout') -%>
<div style="max-width: 600px;">
  <h2>Add New Student</h2>
  
  <form action="/students" method="post">
    <div>
      <label>Full Name</label>
      <input name="name" type="text" required placeholder="e.g., John Doe">
    </div>
    
    <div>
      <label>Student Number (Optional)</label>
      <input name="student_number" type="text" placeholder="e.g., S12345">
    </div>
    
    <button type="submit" class="success" style="margin-top: 20px;">Add Student</button>
    <a href="/students" style="margin-left: 10px; display: inline-block; padding: 12px 24px; background: #e5e7eb; color: #1f2937; border-radius: 8px; font-weight: 600; transition: all 0.3s ease;" onmouseover="this.style.background='#d1d5db'" onmouseout="this.style.background='#e5e7eb'">Cancel</a>
  </form>
</div>
