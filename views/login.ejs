<% layout('layout') -%>
<div class="card" style="max-width: 500px; margin: 40px auto;">
  <h2>Sign In</h2>
  <p style="color: #6b7280; font-size: 15px; margin-bottom: 25px;">Enter your credentials to access the attendance system</p>
  
  <form action="/login" method="post">
    <div>
      <label>Username</label>
      <input name="username" type="text" required placeholder="Enter your username">
    </div>
    
    <div>
      <label>Password</label>
      <input name="password" type="password" required placeholder="Enter your password">
    </div>
    
    <button type="submit" style="width: 100%; margin-top: 10px;">Sign In</button>
  </form>

  <p style="text-align: center; margin-top: 20px; font-size: 14px; color: #6b7280;">
    Demo Accounts:<br>
    <strong>Admin:</strong> admin / 123<br>
    <strong>Student:</strong> student / 321
  </p>
</div>
