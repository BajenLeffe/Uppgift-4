<% layout('layout') -%>
<h2>My Attendance</h2>
<p>Your attendance records:</p>
<table>
  <thead>
    <tr>
      <th>Date</th>
      <th>Status</th>
      <th>Delay (minutes)</th>
    </tr>
  </thead>
  <tbody>
    <% if (attendance && attendance.length > 0) { %>
      <% attendance.forEach(a => { %>
        <tr>
          <td><%= a.date %></td>
          <td><strong><%= a.status %></strong></td>
          <td><%= a.delay_minutes ? a.delay_minutes : '—' %></td>
        </tr>
      <% }) %>
    <% } else { %>
      <tr>
        <td colspan="3">No attendance records yet</td>
      </tr>
    <% } %>
  </tbody>
</table>
<style>
  table { width: 100%; border-collapse: collapse; margin-top: 20px; }
  th, td { border: 1px solid #ddd; padding: 10px; text-align: left; }
  th { background-color: #f0f0f0; }
</style>
