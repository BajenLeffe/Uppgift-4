<% layout('layout') -%>
<div style="max-width: 900px; margin: 60px auto; text-align: center;">
  <h2 style="font-size: 36px; margin-bottom: 20px; color: #1f2937;">Welcome to the Attendance System</h2>
  
  <p style="font-size: 18px; color: #6b7280; margin-bottom: 40px; line-height: 1.8;">
    Manage and track student attendance efficiently.<br>
    Sign in to get started.
  </p>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-bottom: 40px;">
    <div class="card">
      <div style="font-size: 40px; margin-bottom: 15px;">📋</div>
      <h3 style="color: #1f2937;">Student List</h3>
      <p style="font-size: 14px;">View and manage all enrolled students</p>
    </div>

    <div class="card">
      <div style="font-size: 40px; margin-bottom: 15px;">✓</div>
      <h3 style="color: #1f2937;">Mark Attendance</h3>
      <p style="font-size: 14px;">Register daily attendance with status tracking</p>
    </div>

    <div class="card">
      <div style="font-size: 40px; margin-bottom: 15px;">📊</div>
      <h3 style="color: #1f2937;">View History</h3>
      <p style="font-size: 14px;">Access complete attendance records</p>
    </div>
  </div>

  <a href="/login" class="btn" style="display: inline-block; padding: 15px 40px; font-size: 16px; background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%); border: none;">Sign In Now</a>

  <div style="margin-top: 60px; padding-top: 40px; border-top: 2px solid #e5e7eb;">
    <p style="color: #6b7280; font-size: 14px; margin-bottom: 15px;">Need a demo account?</p>
    <div style="background: #f3f4f6; padding: 20px; border-radius: 8px; text-align: left; display: inline-block;">
      <p style="margin: 5px 0; color: #1f2937;"><strong>Admin Account:</strong><br><span style="font-family: monospace; color: #6b7280;">Username: admin | Password: 123</span></p>
      <p style="margin: 15px 0 5px 0; color: #1f2937;"><strong>Student Account:</strong><br><span style="font-family: monospace; color: #6b7280;">Username: student | Password: 321</span></p>
    </div>
  </div>
</div>
