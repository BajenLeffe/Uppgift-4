<% layout('layout') -%>
<div style="max-width: 800px;">
  <h2>Student Management</h2>
  
  <div style="margin-bottom: 25px;">
    <a href="/students/new" class="btn" style="display: inline-block; background: #10b981;">+ Add New Student</a>
  </div>

  <% if (students && students.length > 0) { %>
    <div style="display: grid; gap: 12px;">
      <% students.forEach(s => { %>
        <div class="card" style="padding: 16px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 0;">
          <div>
            <strong style="font-size: 16px; display: block; margin-bottom: 4px;"><%= s.name %></strong>
            <% if (s.student_number) { %>
              <span style="font-size: 13px; color: #6b7280;">ID: <%= s.student_number %></span>
            <% } %>
          </div>
          <span style="font-size: 12px; color: #9ca3af; background: #f3f4f6; padding: 4px 12px; border-radius: 20px;">Student</span>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div style="background: #f3f4f6; padding: 40px; border-radius: 8px; text-align: center;">
      <p style="color: #6b7280; font-size: 16px;">No students yet.</p>
      <a href="/students/new" class="btn" style="display: inline-block; margin-top: 15px;">Add First Student</a>
    </div>
  <% } %>
</div>
